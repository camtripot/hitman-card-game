{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "../models/*": ["../src/models/*"],
      "../engine/*": ["../src/engine/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../src/models/**/*", "../src/engine/**/*"]
}
